{% extends 'base.html.twig' %}
{% block head %}
	<meta property="og:title" content="{{ producto.nombre }}"/>
	<meta property="og:description" content="{{ producto.descripcion }}"/>
{% endblock %}

{% block body %}
	<style>
		body {
			font-family: 'Poppins', sans-serif;
		}
		.nav-item {
			font-weight: bold;
			text-transform: uppercase;
		}
	</style>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="collapse navbar-collapse" id="navbarNav">
			<a class="navbar-brand mx-auto text-center" href="{{ path('inicio') }}">
				<h1 style="font-family: 'Poppins', sans-serif; font-size: 5rem; font-weight: bold; text-transform: uppercase;">FanVerse</h1>
			</a>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<ul class="navbar-nav ml-auto">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('carrito') }}">
						<img src="https://img.icons8.com/external-vitaliy-gorbachev-flat-vitaly-gorbachev/512/external-shopping-cart-sales-vitaliy-gorbachev-flat-vitaly-gorbachev.png" alt="carrito" width="30" height="30">
						<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
					</a>
				</li>

				{% if app.user %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('verPerfil') }}">{{ app.user.nombre }}</a>
					</li>

					<li class="nav-item">
						<a class="nav-link" href="{{ path('logout') }}">Logout</a>
					</li>
				{% else %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_login') }}">Login</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
					</li>
				{% endif %}
			</ul>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center w-100 justify-content-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
					<li class="nav-item">
						<form class="form-inline my-2 my-lg-0" action="{{ path('productos_por_nombre') }}" method="get">
							<div class="input-group">
								<input type="text" class="form-control" placeholder="Buscar" name="nombre">
								<div class="input-group-append">
									<button class="btn btn-outline-secondary" type="submit" style="background-color: #ff8ba7;">
										<i class="fa fa-search"></i>
									</button>
								</div>
							</div>
						</form>
					</li>
				</ul>
			</div>
		</div>
	</nav>
	<div class="container py-5">
		<div class="row">
			<div class="col-md-6">
				<img src="{{ producto.image_link }}" class="img-fluid rounded mb-4" alt="{{ producto.nombre }}">
			</div>
			<div class="col-md-6">
				<h1 class="mb-4">{{ producto.nombre }}</h1>
				<p class="text-muted mb-4">{{ producto.descripcion }}</p>
				<p class="h4 mb-4">{{ producto.precio }}€</p>
				{#TALLAS Y TAMAÑOS#}
				{% if producto.categoria == 2 %}
					<p class="text-muted mb-4">Tamaño:
						<select class="form-select" name="tamano" id="tamano">
							<option value="8.5” x 11”">8.5 x 11</option>
							<option value="11” x 14”">11 x 14</option>
							<option value="12” x 18”">12 x 18</option>
							<option value="18” x 24">18 x 24</option>
							<option value="30” x 36">30 x 36</option>
						</select>
					</p>
				{% endif %}

				{% if producto.categoria == 3 %}
					<p class="text-muted mb-4">Talla:
						<select class="form-select" name="talla" id="talla">
							<option value="S">S</option>
							<option value="M">M</option>
							<option value="L">L</option>
							<option value="XL">XL</option>
						</select>
					</p>
				{% endif %}

				<p class="text-muted mb-4">Tiempo de envío: 48h</p>
				<form method="post" action="{{ path('agregar_al_carrito', {'codprod': producto.codprod}) }}">
					<input type="number" name="cantidad" class="form-control mb-3" placeholder="Cantidad" min="1" value="1" required>
					<button type="submit" class="btn btn-primary btn-block">Añadir al carrito</button>
				</form>
			</div>
			<div class="my-5">
				<h2>Compartir en redes sociales:</h2>
				<div class="d-flex align-items-center justify-content-center">
					<a href="https://www.facebook.com/sharer/sharer.php?u={{ path('producto', {'codprod': producto.codprod}) }}&title={{ producto.nombre }}" target="_blank" class="btn btn-primary mx-2">
						<i class="fab fa-facebook fa-2x"></i>
					</a>
					<a href="https://twitter.com/intent/tweet?url={{ path('producto', {'codprod': producto.codprod}) }}&text={{ producto.nombre }}" target="_blank" class="btn btn-primary mx-2">
						<i class="fab fa-twitter fa-2x"></i>
					</a>
				</div>
			</div>


		</div>
	</div>
{% endblock %}
