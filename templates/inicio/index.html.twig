{% extends 'base.html.twig' %}

{% block body %}
	<style>
		body {
			font-family: 'Poppins', sans-serif;
		}
		.nav-item {
			font-weight: bold;
			text-transform: uppercase;
		}
	</style>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="collapse navbar-collapse" id="navbarNav">
			<a class="navbar-brand mx-auto text-center" href="{{ path('inicio') }}">
				<h1 style="font-family: 'Poppins', sans-serif; font-size: 5rem; font-weight: bold; text-transform: uppercase;">FanVerse</h1>
			</a>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<ul class="navbar-nav ml-auto">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('carrito') }}">
						<img src="https://img.icons8.com/external-vitaliy-gorbachev-flat-vitaly-gorbachev/512/external-shopping-cart-sales-vitaliy-gorbachev-flat-vitaly-gorbachev.png" alt="carrito" width="30" height="30">
						<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
					</a>
				</li>

				{% if app.user %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('verPerfil') }}">{{ app.user.nombre }}</a>
					</li>

					<li class="nav-item">
						<a class="nav-link" href="{{ path('logout') }}">Logout</a>
					</li>
				{% else %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_login') }}">Login</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
					</li>
				{% endif %}
			</ul>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center w-100 justify-content-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
					<li class="nav-item dropdown">
						<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
							Categorias
						</a>
						<div class="dropdown-menu" aria-labelledby="navbarDropdown">
							{% for categoria in categorias %}
								<a class="dropdown-item" href="{{ path('productos_por_categoria', {'categoria': categoria.categoria}) }}">{{ categoria.nombre }}</a>
							{% endfor %}
						</div>
					</li>
					<li class="nav-item">
						<form class="form-inline my-2 my-lg-0" action="{{ path('productos_por_nombre') }}" method="get">
							<div class="input-group">
								<input type="text" class="form-control" placeholder="Buscar" name="nombre">
								<div class="input-group-append">
									<button class="btn btn-outline-secondary" type="submit" style="background-color: #ff8ba7;">
										<i class="fa fa-search"></i>
									</button>
								</div>
							</div>
						</form>
					</li>
				</ul>
			</div>
		</div>
	</nav>
	<div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel">
		<ol class="carousel-indicators">
			<li data-target="#carouselExampleIndicators" data-slide-to="0" class="active"></li>
			<li data-target="#carouselExampleIndicators" data-slide-to="1"></li>
			<li data-target="#carouselExampleIndicators" data-slide-to="2"></li>
		</ol>
		<div class="carousel-inner">
			<div
				class="carousel-item active">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="First slide" width="200" height="400">
			</div>
			<div
				class="carousel-item">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="Second slide" width="200" height="400">
			</div>
			<div
				class="carousel-item">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="Third slide" width="200" height="400">
			</div>
		</div>
		<a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
			<span class="carousel-control-prev-icon" aria-hidden="true"></span>
			<span class="sr-only">Previous</span>
		</a>
		<a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
			<span class="carousel-control-next-icon" aria-hidden="true"></span>
			<span class="sr-only">Next</span>
		</a>
	</div>
	<div class="container mt-4">
		<h2 class="text-center mb-4">Productos más recientes</h2>
		<div class="row row-cols-1 row-cols-md-3 g-4">
			{% for producto in productosRecientes %}
				<div class="col">
					<div class="card h-100">
						<img src="{{ producto.image_link }}" class="card-img-top w-100 h-auto" alt="{{ producto.nombre }}">
						<div class="card-body">
							<h5 class="card-title">{{ producto.nombre }}</h5>
							<p class="card-text">{{ producto.descripcion }}</p>
							<p class="card-text">{{ producto.precio }}€</p>
							<a href="{{ path('producto', {'codprod': producto.codprod}) }}" class="btn btn-pink">Ver más</a>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>

	<style>
		.btn-pink {
			background-color: #ff8ba7;
		}
	</style>
</div>{% endblock %}
