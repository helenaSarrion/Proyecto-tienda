{% extends 'base.html.twig' %}

{% block body %}
	<style>
		body {
			font-family: 'Poppins', sans-serif;
		}
		.nav-item {
			font-weight: bold;
			text-transform: uppercase;
		}
	</style>

	<nav class="navbar navbar-expand-lg navbar-light bg-transparent ">
		<a class="navbar-brand" href="{{ path('inicio') }}">FANVERSE</a>
		<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="container">
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center w-100 justify-content-center align-items-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
				</ul>
			</div>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav ml-auto">
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('verPerfil') }}">{{ app.user.nombre }}</a>
						</li>

						<li class="nav-item">
							<a class="nav-link" href="{{ path('logout') }}">Logout</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_login') }}">Login</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
						</li>
					{% endif %}
				</ul>
			</div>
		</div>
	</nav>
	<div class="container mt-5">
		<div class="card">
			<div class="card-header">
				<h1 class="card-title">Usuario:
					{{ nombre }}</h1>
			</div>
			<div class="card-body">
				<p class="card-text">
					<strong>Correo electrónico:</strong>
					{{ email }}
				</p>
			</div>
		</div>
		<div class="card-title mt-5">
			<h2>Editar contraseña</h2>
		</div>
		<div class="card-body">
			<form method="post" action="{{ path('cambiar_contrasena') }}">
				<div class="form-group">
					<label for="password">Contraseña</label>
					<input type="password" class="form-control" id="password" name="password" placeholder="Contraseña">
				</div>
				<div class="form-group">
					<label for="password2">Repetir contraseña</label>
					<input type="password" class="form-control" id="password2" name="password2" placeholder="Repetir contraseña">
				</div>
				<button type="submit" class="btn btn-primary">Cambiar contraseña</button>
			</form>
		</div>

	</div>
{% endblock %}
