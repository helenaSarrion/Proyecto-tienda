{% extends 'base.html.twig' %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<div class="collapse navbar-collapse" id="navbarNav">
				<a class="navbar-brand mx-auto text-center text-black rounded-lg py-2 px-3" href="{{ path('inicio') }}">
					<h1 class="m-0">FanVerse</h1>
				</a>
				<ul class="navbar-nav">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('carrito') }}">
							<i class="fas fa-shopping-cart fa-lg">Cesta</i>
							<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
						</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('logout') }}">Logout</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_login') }}">Login</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
						</li>
					{% endif %}
				</ul>
			</nav>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
					<li class="nav-item dropdown">
						<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
							Categorias
						</a>
						<div class="dropdown-menu" aria-labelledby="navbarDropdown">
							{% for categoria in categorias %}
								<a class="dropdown-item" href="{{ path('productos_por_categoria', {'categoria': categoria.categoria}) }}">{{ categoria.nombre }}</a>
							{% endfor %}
						</div>
					</li>
				</ul>

			</div>
		</div>
	</nav>


	<div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel">
		<ol class="carousel-indicators">
			<li data-target="#carouselExampleIndicators" data-slide-to="0" class="active"></li>
			<li data-target="#carouselExampleIndicators" data-slide-to="1"></li>
			<li data-target="#carouselExampleIndicators" data-slide-to="2"></li>
		</ol>
		<div class="carousel-inner">
			<div
				class="carousel-item active">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="First slide" width="200" height="200">
			</div>
			<div
				class="carousel-item">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="Second slide" width="200" height="200">
			</div>
			<div
				class="carousel-item">
				{#aqui se van a mostrar las imagenes de las ofertas de la semana#}
				<img class="d-block w-100" src="https://banco-imagenes-helen.s3.eu-north-1.amazonaws.com/header.png" alt="Third slide" width="200" height="200">
			</div>
		</div>
		<a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
			<span class="carousel-control-prev-icon" aria-hidden="true"></span>
			<span class="sr-only">Previous</span>
		</a>
		<a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
			<span class="carousel-control-next-icon" aria-hidden="true"></span>
			<span class="sr-only">Next</span>
		</a>
	</div>

	<hr>
	<footer class="mt-5">
		<div class="row">
			<div class="col-md-8">
				<p>Somos una tienda de merchandising en línea que se especializa en productos con diseños propios de alta calidad, inspirados en tus bandas, series y películas favoritas.</p>
			</div>
			<div class="col-md-4">
				<h4>Contacto</h4>
				<p>Correo electrónico: tienda@fanverse.com</p>
				<p>Teléfono: +34 234 567 890</p>
			</div>
		</div>
		<div class="row mt-5">
			<div class="col-md-12 text-center">
				<a href="https://www.facebook.com/"><img src="https://img.icons8.com/color/48/000000/facebook-new.png"/></a>
				<a href="https://www.instagram.com/"><img src="https://img.icons8.com/color/48/000000/instagram-new.png"/></a>
				<a href="https://twitter.com/"><img src="https://img.icons8.com/color/48/000000/twitter.png"/></a>
				<a href="https://www.tiktok.com/"><img src="https://img.icons8.com/color/48/000000/tiktok.png"/></a>
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center">
				<p>&copy;
					{{ "now"|date("Y") }}
					Todos los derechos reservados</p>
			</div>
		</div>
	</footer>
</div>{% endblock %}
