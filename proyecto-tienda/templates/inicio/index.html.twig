{% extends 'base.html.twig' %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-light">
		<a class="navbar-brand">FanVerse</a>
		<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="collapse navbar-collapse" id="navbarNav">
			<ul class="navbar-nav">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('nosotros') }}">Nosotros<span class="sr-only">(current)</span>
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="{{ path('app_login') }}">Login<span class="sr-only">(current)</span></a> 
				</li>
				<li class="nav-item">
                    <a class="nav-link" href="{{ path('registro') }}">Registrarse<span class="sr-only">(current)</span></a> 
				</li>
				<li class="nav-item">
                    <a class="nav-link" href="{{ path('carrito') }}">Carrito<span class="sr-only">(current)</span></a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="{{path('productos')}}">Productos<span class="sr-only">(current)</span></a>
				</li>
				{% if app.user %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('logout') }}">Logout<span class="sr-only">(current)</span></a> 
					</li>
				{% endif %}
			</ul>
		</div>
	</nav>
	<h1>{{ mensaje }}</h1>
{% endblock %}
