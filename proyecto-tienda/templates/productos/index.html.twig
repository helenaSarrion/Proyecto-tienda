{% extends 'base.html.twig' %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<a class="navbar-brand" href="#">FanVerse</a>
			<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
					<li class="nav-item dropdown">
						<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
							Categorias
						</a>
						<div class="dropdown-menu" aria-labelledby="navbarDropdown">
							{% for categoria in categorias %}
								<a class="dropdown-item" href="{{ path('productos_por_categoria', {'categoria': categoria.categoria}) }}">{{ categoria.nombre }}</a>
							{% endfor %}
						</div>
					</li>
				</ul>
				<ul class="navbar-nav">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('carrito') }}">
							<i class="fas fa-shopping-cart fa-lg">Cesta</i>
							<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
						</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('logout') }}">Logout</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_login') }}">Login</a>
						</li>
						{% if app.user %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('mi_cuenta') }}">Mi cuenta</a>
							</li>
						{% endif %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
						</li>
					{% endif %}
				</ul>
			</div>
		</div>
	</nav>

	<div class="container my-5">
		<div class="text-left">
			<form class="form-inline" method="GET" action="{{ path('productos') }}">
				<div class="form-group">
					<label for="precio">Filtrar por precio:</label>
					<select class="form-control" id="precio" name="precio" onchange="this.form.submit()">
						<option value="">Selecciona uno</option>
						<option value="-1">Todos</option>
						<option value="0-50">Menos de 50€</option>
						<option value="50-100">50€ - 100€</option>
						<option value="100-200">100€ - 200€</option>
						<option value="200+">Más de 200€</option>
					</select>
				</div>
			</form>
		</div>
		<br><br>
		<div class="row">
			{% for producto in productos %}
				<div class="col-md-3">
					<div class="card mb-4">
						<img src="{{ producto.image_link }}" class="card-img-top" alt="{{ producto.nombre }}">
						<div class="card-body">
							<h5 class="card-title">{{ producto.nombre }}</h5>
							<p class="card-text">{{ producto.precio|number_format(2, ',', '.') }}
								€</p>
							<button type="button" class="btn btn-primary">Añadir al carrito</button>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>

	</div>
</div>
<hr>
<div class="row mt-5">
	<div class="col-md-12 text-center">
		<a href="https://www.facebook.com/"><img src="https://img.icons8.com/color/48/000000/facebook-new.png"/></a>
		<a href="https://www.instagram.com/"><img src="https://img.icons8.com/color/48/000000/instagram-new.png"/></a>
		<a href="https://twitter.com/"><img src="https://img.icons8.com/color/48/000000/twitter.png"/></a>
		<a href="https://www.tiktok.com/"><img src="https://img.icons8.com/color/48/000000/tiktok.png"/></a>
	</div>
</div>
<footer class="mt-5">
	<div class="row">
		<div class="col-md-8">
			<p>Somos una tienda de merchandising en línea que se especializa en productos con diseños propios de alta calidad, inspirados en tus bandas, series y películas favoritas.</p>
		</div>
		<div class="col-md-4">
			<h4>Contacto</h4>
			<p>Correo electrónico: tienda@fanverse.com</p>
			<p>Teléfono: +34 234 567 890</p>
		</div>
	</div>
	<div class="row">
		<div class="col-md-12 text-center">
			<p>&copy;
				{{ "now"|date("Y") }}
				Todos los derechos reservados</p>
		</div>
	</div>
</footer></div>{% endblock %}
