{% extends 'base.html.twig' %}

{% block title %}Inicio sesion
{% endblock %}

{% block body %}
	<style>
		body {
			font-family: 'Poppins', sans-serif;
		}
	</style>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="collapse navbar-collapse" id="navbarNav">
			<a class="navbar-brand mx-auto text-center" href="{{ path('inicio') }}">
				<h1 style="font-family: 'Poppins', sans-serif; font-size: 5rem; font-weight: bold; text-transform: uppercase;">FanVerse</h1>
			</a>
		</div>
	</nav>
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<ul class="navbar-nav ml-auto">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('carrito') }}">
						<img src="https://img.icons8.com/external-vitaliy-gorbachev-flat-vitaly-gorbachev/512/external-shopping-cart-sales-vitaliy-gorbachev-flat-vitaly-gorbachev.png" alt="carrito" width="30" height="30"></i>
					<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
				</li>
			</a>
		</li>
		{% if app.user %}
			<li class="nav-item">
				<a class="nav-link" href="{{ path('logout') }}">Logout</a>
			</li>
		{% else %}
			<li class="nav-item">
				<a class="nav-link" href="{{ path('app_login') }}">Login</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
			</li>
		{% endif %}
	</ul>
</div></nav><nav class="navbar navbar-expand-lg navbar-light bg-transparent">
<div class="container">
	<div class="collapse navbar-collapse" id="navbarNav">
		<ul class="navbar-nav mx-auto text-center w-100 justify-content-center">
			<li class="nav-item">
				<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
			</li>
		</ul>
	</div>
</nav>
<div class="container my-5">
	<div class="row justify-content-center">
		<div class="col-lg-6">
			<div class="card shadow-lg border-0 rounded-lg mt-5">
				<div class="card-header bg-transparent">
					<h3 class="text-center font-weight-light my-4">Iniciar sesión</h3>
				</div>
				<div class="card-body">
					<form method="post">
						{% if error %}
							<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
						{% endif %}
						{% if app.user %}
							<div class="mb-3">
								Has iniciado sesión como
								{{ app.user.username }},
								<a href="{{ path('app_logout') }}">Cerrar sesión</a>
							</div>
						{% endif %}
						<div class="form-floating mb-3">
							<input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" placeholder="Email" autocomplete="email" required autofocus>
							<label for="inputEmail"></label>
						</div>
						<div class="form-floating mb-3">
							<input type="password" name="password" id="inputPassword" class="form-control" placeholder="Password" autocomplete="current-password" required>
							<label for="inputPassword"></label>
						</div>
						<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
						<button class="btn btn-secondary btn-block mt-4">Iniciar sesión</button>
						<div class="d-flex justify-content-between align-items-center mt-4">
							<a href="{{ path('registro') }}" class="text-primary">Crear cuenta</a>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div></div><hr>{% endblock %}
