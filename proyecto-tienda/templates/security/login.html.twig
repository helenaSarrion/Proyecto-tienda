{% extends 'base.html.twig' %}

{% block title %}Inicio sesion
{% endblock %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<a class="navbar-brand" href="#">FanVerse</a>
			<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
				</ul>
				<ul class="navbar-nav">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('carrito') }}">
							<i class="fas fa-shopping-cart fa-lg">Cesta</i>
							<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
						</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('logout') }}">Logout</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_login') }}">Login</a>
						</li>
						{% if app.user %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('mi_cuenta') }}">Mi cuenta</a>
							</li>
						{% endif %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
						</li>
					{% endif %}
				</ul>
			</div>
		</div>
	</nav>
	<div class="container my-5">
		<div class="row justify-content-center">
			<div class="col-lg-6">
				<div class="card shadow-lg border-0 rounded-lg mt-5">
					<div class="card-header bg-transparent">
						<h3 class="text-center font-weight-light my-4">Iniciar sesión</h3>
					</div>
					<div class="card-body">
						<form method="post">
							{% if error %}
								<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
							{% endif %}
							{% if app.user %}
								<div class="mb-3">
									Has iniciado sesión como
									{{ app.user.username }},
									<a href="{{ path('app_logout') }}">Cerrar sesión</a>
								</div>
							{% endif %}
							<div class="form-floating mb-3">
								<input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" placeholder="Email" autocomplete="email" required autofocus>
								<label for="inputEmail">Email</label>
							</div>
							<div class="form-floating mb-3">
								<input type="password" name="password" id="inputPassword" class="form-control" placeholder="Password" autocomplete="current-password" required>
								<label for="inputPassword">Password</label>
							</div>
							<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
							<button class="btn btn-secondary btn-block mt-4">Iniciar sesión</button>
							<div class="d-flex justify-content-between align-items-center mt-4">
								<a href="{{ path('registro') }}" class="text-primary">Crear cuenta</a>
								<a href="#" class="text-primary">Olvidaste tu contraseña?</a>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<hr>
<div class="row mt-5">
	<div class="col-md-12 text-center">
		<a href="https://www.facebook.com/"><img src="https://img.icons8.com/color/48/000000/facebook-new.png"/></a>
		<a href="https://www.instagram.com/"><img src="https://img.icons8.com/color/48/000000/instagram-new.png"/></a>
		<a href="https://twitter.com/"><img src="https://img.icons8.com/color/48/000000/twitter.png"/></a>
		<a href="https://www.tiktok.com/"><img src="https://img.icons8.com/color/48/000000/tiktok.png"/></a>
	</div>
</div>
<footer class="mt-5">
	<div class="row">
		<div class="col-md-12 text-center">
			<p>&copy;
				{{ "now"|date("Y") }}
				Todos los derechos reservados</p>
		</div>
	</div>
</footer>{% endblock %}
