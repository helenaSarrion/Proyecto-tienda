{% extends 'base.html.twig' %}

{% block title %}Registro
{% endblock %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-light">
		<a class="navbar-brand" href="{{ path('inicio') }}">FanVerse</a>
		<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="collapse navbar-collapse" id="navbarNav">
			<ul class="navbar-nav mr-auto">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('nosotros') }}">Nosotros</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="{{ path('productos') }}">Productos</a>
				</li>
			</ul>
			<ul class="navbar-nav">
				<li class="nav-item">
					<a class="nav-link" href="{{ path('carrito') }}">
						<i class="fas fa-shopping-cart fa-lg">Cesta</i>
						<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
					</a>
				</li>
				{% if app.user %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('logout') }}">Logout</a>
					</li>
				{% else %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_login') }}">Login</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('mi_cuenta') }}">Mi cuenta</a>
						</li>
					{% endif %}
					<li class="nav-item">
						<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
					</li>
				{% endif %}
			</ul>
		</div>
	</nav>
	<div class="container">
		<div class="row justify-content-center mt-5">
			<div class="col-md-6">
				<div class="card">
					<div class="card-body">
						<h1 class="card-title text-center mb-4">Registro</h1>
						<form method="post" action="{{ path('registro') }}">
							<div class="form-group">
								<label for="nombre">Nombre</label>
								<input type="text" class="form-control" id="nombre" name="nombre" placeholder="Introduce tu nombre" required>
							</div>
							<div class="form-group">
								<label for="email">Email</label>
								<input type="email" class="form-control" id="email" name="email" placeholder="Introduce tu email" required>
							</div>

							<div class="form-group">
								<label for="password">Contraseña</label>
								<input type="password" class="form-control" id="password" name="password" placeholder="Introduce tu contraseña" required>
							</div>

							<div class="form-group">
								<label for="password_confirmation">Confirmar contraseña</label>
								<input type="password" class="form-control" id="password_confirmation" name="password_confirmation" placeholder="Introduce nuevamente tu contraseña" required>
							</div>

							<button type="submit" class="btn btn-primary btn-block mt-4">Registrarse</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
