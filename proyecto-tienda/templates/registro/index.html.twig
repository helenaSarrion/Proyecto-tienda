{% extends 'base.html.twig' %}

{% block title %}Registro
{% endblock %}

{% block body %}
	<nav class="navbar navbar-expand-lg navbar-light bg-transparent">
		<div class="container">
			<a class="navbar-brand" href="#">FanVerse</a>
			<button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto text-center">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('inicio') }}">Inicio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('nosotros') }}">Sobre nosotros</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('productos') }}">Tienda</a>
					</li>
				</ul>
				<ul class="navbar-nav">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('carrito') }}">
							<i class="fas fa-shopping-cart fa-lg">Cesta</i>
							<span class="badge badge-pill badge-primary">{{ app.session.get('carrito')|length }}</span>
						</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('logout') }}">Logout</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_login') }}">Login</a>
						</li>
						{% if app.user %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('mi_cuenta') }}">Mi cuenta</a>
							</li>
						{% endif %}
						<li class="nav-item">
							<a class="nav-link" href="{{ path('registro') }}">Registrarse</a>
						</li>
					{% endif %}
				</ul>
			</div>
		</div>
	</nav>
	<div class="container my-5">
		<div class="row justify-content-center">
			<div class="col-md-6">
				<div class="card shadow-lg border-0 rounded-lg">
					<div class="card-header">
						<h3 class="text-center font-weight-light my-4">Registro</h3>
					</div>
					<div class="card-body">
						<form method="post" action="{{ path('registro') }}">
							<div class="mb-3">
								<label for="nombre" class="form-label">Nombre</label>
								<input type="text" class="form-control" id="nombre" name="nombre" placeholder="Introduce tu nombre" required>
							</div>
							<div class="mb-3">
								<label for="email" class="form-label">Email</label>
								<input type="email" class="form-control" id="email" name="email" placeholder="Introduce tu email" required>
							</div>
							<div class="mb-3">
								<label for="password" class="form-label">Contraseña</label>
								<input type="password" class="form-control" id="password" name="password" placeholder="Introduce tu contraseña" required>
							</div>
							<div class="mb-3">
								<label for="password_confirmation" class="form-label">Confirmar contraseña</label>
								<input type="password" class="form-control" id="password_confirmation" name="password_confirmation" placeholder="Introduce nuevamente tu contraseña" required>
							</div>
							<div class="d-grid">
								<button type="submit" class="btn btn-secondary btn-block mt-4">Registrarse</button>


							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
	<hr>
	<div class="row mt-5">
		<div class="col-md-12 text-center">
			<a href="https://www.facebook.com/"><img src="https://img.icons8.com/color/48/000000/facebook-new.png"/></a>
			<a href="https://www.instagram.com/"><img src="https://img.icons8.com/color/48/000000/instagram-new.png"/></a>
			<a href="https://twitter.com/"><img src="https://img.icons8.com/color/48/000000/twitter.png"/></a>
			<a href="https://www.tiktok.com/"><img src="https://img.icons8.com/color/48/000000/tiktok.png"/></a>
		</div>
	</div>
	<footer class="mt-5">
		<div class="row">
			<div class="col-md-12 text-center">
				<p>&copy;
					{{ "now"|date("Y") }}
					Todos los derechos reservados</p>
			</div>
		</div>
	</footer>

{% endblock %}
